    10 00000006 8ED8                    mov ds, ax
    11 00000008 BA[1700]                mov dx, newISR
    12 0000000B B86025                  mov ax, 2560h ;loads two values, ah = 25h (set intterupt vector) , al= 60h 9set interrupt number)
    13 0000000E CD21                    int 21h
    14 00000010 FB                      sti   ;set interrupt flag 
    15                                  
    16 00000011 CD60                    int 60h   ; call it
    17                                  
    18                                  ; exit
    19 00000013 B44C                    mov ah, 4Ch
    20 00000015 CD21                    int 21h
