     1                                  [org 0x0100]
     2                                  
     3 00000000 B406                    mov ah, 0x06         ; Scroll up function
     4 00000002 B000                    mov al, 0            ; Clear entire screen
     5 00000004 B707                    mov bh, 0x07         ; Attribute (white on black)
     6 00000006 B90000                  mov cx, 0x0000       ; Upper-left corner (row=0, col=0)
     7 00000009 BA4F18                  mov dx, 0x184F       ; Lower-right corner (row=24, col=79)
     8 0000000C CD10                    int 0x10             ; Call video interrupt
     9                                  
    10                                  
    11                                  ; Display 'A' at top-left corner
    12 0000000E B800B8                  mov ax, 0xB800       ; Video memory segment
    13 00000011 8EC0                    mov es, ax
    14 00000013 31FF                    xor di, di           ; Offset 0 -> top-left corner
    15                                  
    16 00000015 B041                    mov al, 'A'          ; Character to print
    17 00000017 B41E                    mov ah, 0x1E         ; Color: yellow on blue (you can change this)
    18 00000019 268905                  mov [es:di], ax      ; Write character + color to video memory
    19                                  
    20 0000001C B400                    mov ah, 0x00
    21 0000001E CD16                    int 0x16             ; BIOS keyboard input (waits for key)
    22                                  
    23                                  
    24 00000020 B8004C                  mov ax, 0x4C00
    25 00000023 CD21                    int 0x21
