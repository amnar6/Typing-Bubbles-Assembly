     1                                  [org 0x0100]
     2                                  
     3 00000000 E90600                  jmp start
     4                                  
     5 00000003 0101                    dividend : dw 257       ; 16-bit number
     6 00000005 0A                      divisor  : db 10        ; 8-bit divisor
     7 00000006 0000                    quotient : dw 0
     8 00000008 00                      remainder: db 0
     9                                  
    10                                  start:
    11 00000009 A1[0300]                    mov ax, [dividend]   ; AX = dividend
    12 0000000C 8A1E[0500]                  mov bl, [divisor]    ; BL = divisor
    13 00000010 31C9                        xor cx, cx           ; CX = quotient = 0
    14                                  
    15                                  divide_loop:
    16 00000012 39D8                        cmp ax, bx           ; if dividend < divisor, done
    17 00000014 7205                        jb done
    18 00000016 29D8                        sub ax, bx           ; subtract divisor
    19 00000018 41                          inc cx               ; quotient++
    20 00000019 EBF7                        jmp divide_loop
    21                                  
    22                                  done:
    23 0000001B 890E[0600]                  mov [quotient], cx   ; store quotient
    24 0000001F A2[0800]                    mov [remainder], al  ; remainder fits in 8-bit
    25                                  
    26 00000022 B8004C                      mov ax, 0x4c00
    27 00000025 CD21                        int 0x21
