     1                                  [org 0x0100]
     2                                  
     3 00000000 E90500                  jmp start
     4                                  
     5 00000003 A7A394FF00              Array db 0A7h, 0A3h, 094h, 0FFh, 00h    ; Original data (5 bytes)
     6                                  
     7                                  start:
     8 00000008 BE0000                      mov si, 0        ; Source index (reads all elements)
     9 0000000B BF0000                      mov di, 0        ; Destination index (for even-parity values)
    10 0000000E B90500                      mov cx, 5        ; Process 5 elements
    11                                  
    12                                  NextByte:
    13 00000011 8A84[0300]                  mov al, [Array + si]   ; Load current byte
    14 00000015 88C3                        mov bl, al             ; Copy original byte to BL for bit counting
    15 00000017 30FF                        xor bh, bh             ; Clear BH (bit counter)  !!
    16 00000019 B208                        mov dl, 8              ; Total 8 bits
    17                                  
    18                                  CountBits:
    19 0000001B D0EB                        shr bl, 1              ; Shift right 1 bit
    20 0000001D 7302                        jnc SkipInc            ; 0 aya
    21 0000001F FEC7                        inc bh                 ; Count 1s in BH
    22                                  	
    23                                  SkipInc:
    24 00000021 FECA                        dec dl
    25 00000023 75F6                        jnz CountBits
    26                                  
    27 00000025 88F8                        mov al, bh
    28 00000027 2401                        and al, 1              ; AL = 0 if even, 1 if odd
    29 00000029 3C00                        cmp al, 0
    30 0000002B 7509                        jne SkipStore          ; Skip if parity is odd
    31                                  
    32                                      ; Store even parity number at current DI
    33 0000002D 8A84[0300]                  mov al, [Array + si]
    34 00000031 8885[0300]                  mov [Array + di], al
    35 00000035 47                          inc di
    36                                  
    37                                  SkipStore:
    38 00000036 46                          inc si
    39 00000037 E2D8                        loop NextByte
    40                                  
    41                                  ;Clear remaining positions
    42                                  ClearRest:
    43 00000039 81FF0500                    cmp di, 5
    44 0000003D 7D08                        jge Done
    45 0000003F C685[0300]00                mov byte [Array + di], 0
    46 00000044 47                          inc di
    47 00000045 EBF2                        jmp ClearRest
    48                                  
    49                                  Done:
    50 00000047 B8004C                    mov ax, 0x4c00
    51 0000004A CD21                      int 0x21
