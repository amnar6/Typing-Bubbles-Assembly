     9                                  ; print message
    10 00000006 B409                    mov ah, 9
    11 00000008 BA[1700]                mov dx, msg
    12 0000000B CD21                    int 21h
    13                                  
    14                                  ; print character
    15 0000000D 88DA                    mov dl, bl
    16 0000000F B402                    mov ah, 2
    17 00000011 CD21                    int 21h
    18                                  
    19                                  ; exit
    20 00000013 B44C                    mov ah, 4CH
    21 00000015 CD21                    int 0x21
