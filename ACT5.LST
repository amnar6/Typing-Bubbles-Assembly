     1                                  [org 0x0100]
     2                                  
     3 00000000 B80000                  mov ax, 0    ; ax = 0, it starts from zero
     4 00000003 BB0500                  mov bx, 5    ; bx = 5, adding 5 to ax register 5 times
     5                                  
     6 00000006 01D8                    add ax, bx      ;1st addition, ax = ax + 5
     7 00000008 01D8                    add ax, bx      ; 2nd
     8 0000000A 01D8                    add ax, bx      ; 3rd
     9 0000000C 01D8                    add ax, bx      ; 4th
    10 0000000E 01D8                    add ax, bx      ; 5th   , ax=25
    11                                  
    12 00000010 B8004C                  mov ax, 0x4c00
    13 00000013 CD21                    int 0x21
